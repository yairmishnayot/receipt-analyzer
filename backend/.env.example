# Google Sheets Configuration
# Option A: Use credentials.json file (set path)
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials.json
# Option B: Use base64-encoded credentials (recommended for production)
# GOOGLE_SHEETS_CREDENTIALS_B64=
GOOGLE_SHEETS_ID=your-spreadsheet-id-here

# Google Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Item Categorization (optional - has defaults)
CATEGORIES_CACHE_PATH=./data/categories.json
CATEGORIES_CACHE_FUZZY_THRESHOLD=80

# Scraping Configuration
SCRAPING_TIMEOUT=30000

# Application Configuration
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# Production: Frontend URL for CORS
# FRONTEND_URL=https://your-frontend.onrender.com
